"use client";
import { useState, useEffect, useCallback } from "react";
import AutoTour from "@/components/AutoTour";

interface StrategyInfo {
  id: string; name: string; icon: string; desc: string;
}

interface RewindData {
  start_date: string; days_ago: number; investment: number;
  start_price: number; end_price: number; bnb_bought: number;
  hold_return_pct: number; hold_final_value: number;
  strategy: string; strategy_info: StrategyInfo;
  strategy_return_pct: number; strategy_trades: number;
  equity_curve: number[];
}

const STRATEGIES: StrategyInfo[] = [
  { id: "hold", name: "Buy & Hold", icon: "💎", desc: "Buy BNB once, never sell" },
  { id: "ma_cross", name: "MA Crossover", icon: "📈", desc: "7d vs 25d moving average crossover" },
  { id: "dca", name: "DCA Weekly", icon: "📅", desc: "Equal buys every week" },
  { id: "rsi", name: "RSI Signal", icon: "📊", desc: "Buy <35 RSI, Sell >70 RSI" },
  { id: "bollinger", name: "Bollinger", icon: "🎯", desc: "Buy lower band, sell upper band" },
  { id: "macd", name: "MACD Cross", icon: "⚡", desc: "Bullish/bearish MACD crossover" },
];

export default function Home() {
  const [showTour, setShowTour] = useState(true);
  const [data, setData] = useState<RewindData | null>(null);
  const [loading, setLoading] = useState(false);
  const [daysAgo, setDaysAgo] = useState(180);
  const [amount, setAmount] = useState(1000);
  const [strategy, setStrategy] = useState("hold");

  const runRewind = useCallback(async () => {
    setLoading(true);
    const res = await fetch(`/api/rewind?days_ago=${daysAgo}&investment=${amount}&strategy=${strategy}`);
    const d = await res.json();
    setData(d);
    setLoading(false);
  }, [daysAgo, amount, strategy]);

  // Auto-fetch whenever strategy/days/amount changes
  useEffect(() => {
    runRewind();
  }, [runRewind]);

  const si = data?.strategy_info;
  const diff = data ? data.strategy_return_pct - data.hold_return_pct : 0;

  // Scale equity curve bars to full range for visual clarity
  const eqMin = data ? Math.min(...data.equity_curve) : 0;
  const eqMax = data ? Math.max(...data.equity_curve) : 1;
  const eqRange = eqMax - eqMin || 1;

  return (
    <main className="min-h-screen bg-[#0a0e17] text-white p-6">
      <div className="max-w-3xl mx-auto">
        {/* Header with BNB branding */}
        <header className="text-center mb-6">
          <div className="flex items-center justify-center gap-3 mb-2">
            <span className="text-5xl">🔮</span>
            <div>
              <h1 className="text-4xl font-black">RewindTrader</h1>
              <div className="flex items-center justify-center gap-2 mt-1">
                <span className="text-2xl">🟡</span>
                <span className="text-lg font-bold text-yellow-400">BNB Chain</span>
                <span className="text-slate-400 text-sm">Time-Travel Backtester</span>
              </div>
            </div>
          </div>
          <p className="text-slate-400 text-base mt-1">
            What if you invested in <span className="text-yellow-400 font-bold">BNB</span> differently in the past?
          </p>
        </header>

        {/* Controls */}
        <div className="bg-gray-900/50 border border-gray-700 rounded-xl p-5 mb-6">
          <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
            {/* Days Ago */}
            <div>
              <label className="text-xs text-slate-400 block mb-2">⏰ Time Period</label>
              <div className="flex gap-1 flex-wrap">
                {[30, 90, 180, 365].map(d => (
                  <button key={d} onClick={() => setDaysAgo(d)}
                    className={`px-3 py-1.5 text-xs rounded font-mono transition-all ${
                      daysAgo === d ? "bg-purple-500 text-white font-bold shadow-lg shadow-purple-500/30" : "bg-gray-700 text-slate-300 hover:bg-gray-600"
                    }`}>{d}d</button>
                ))}
              </div>
            </div>
            {/* Investment */}
            <div>
              <label className="text-xs text-slate-400 block mb-2">💰 Investment</label>
              <div className="flex gap-1 flex-wrap">
                {[100, 500, 1000, 5000].map(a => (
                  <button key={a} onClick={() => setAmount(a)}
                    className={`px-3 py-1.5 text-xs rounded font-mono transition-all ${
                      amount === a ? "bg-purple-500 text-white font-bold shadow-lg shadow-purple-500/30" : "bg-gray-700 text-slate-300 hover:bg-gray-600"
                    }`}>${a}</button>
                ))}
              </div>
            </div>
            {/* Action */}
            <div className="flex items-end">
              <button onClick={runRewind} disabled={loading}
                className="w-full py-3 bg-purple-500 hover:bg-purple-400 text-white font-bold rounded-lg disabled:opacity-50 text-lg transition-all active:scale-95 shadow-lg shadow-purple-500/20">
                {loading ? "⏳ Simulating..." : "⏪ Rewind Time"}
              </button>
            </div>
          </div>

          {/* Strategy selector */}
          <div>
            <label className="text-xs text-slate-400 block mb-2">🧠 Strategy</label>
            <div className="grid grid-cols-3 md:grid-cols-6 gap-2">
              {STRATEGIES.map(s => (
                <button key={s.id} onClick={() => setStrategy(s.id)}
                  className={`p-2 rounded-lg text-xs text-center transition-all ${
                    strategy === s.id
                      ? "bg-purple-500/20 border-2 border-purple-500 text-white shadow-lg shadow-purple-500/20"
                      : "bg-gray-700/50 border border-gray-600 text-slate-400 hover:border-slate-500"
                  }`}
                  title={s.desc}
                >
                  <div className="text-lg">{s.icon}</div>
                  <div className="font-semibold mt-0.5">{s.name}</div>
                </button>
              ))}
            </div>
            {si && strategy !== "hold" && (
              <div className="mt-2 text-xs text-slate-500 italic">{si.icon} {si.desc}</div>
            )}
          </div>
        </div>

        {/* Results */}
        {data && (
          <div className="space-y-4 animate-fade-in">
            {/* BNB Price + Return banner */}
            <div className="bg-gradient-to-r from-yellow-500/10 via-purple-500/10 to-yellow-500/5 border border-yellow-500/20 rounded-xl p-5 text-center">
              <div className="flex items-center justify-center gap-2 mb-1">
                <span className="text-2xl">🟡</span>
                <span className="text-xl font-bold text-yellow-400">BNB</span>
              </div>
              <p className="text-slate-400 text-sm">
                {data.start_date} → Today · ${data.start_price.toFixed(2)} → ${data.end_price.toFixed(2)}
              </p>
              <p className="text-3xl font-black mt-2">
                ${data.investment} →{' '}
                <span className={data.strategy_return_pct >= 0 ? "text-green-400" : "text-red-400"}>
                  ${(data.investment * (1 + data.strategy_return_pct / 100)).toFixed(2)}
                </span>
              </p>
              <div className="flex justify-center gap-6 mt-2">
                <span className="text-sm text-slate-400">
                  基准 Hold: {data.hold_return_pct >= 0 ? "+" : ""}{data.hold_return_pct.toFixed(2)}%
                </span>
                <span className={`text-lg font-bold ${data.strategy_return_pct >= 0 ? "text-green-400" : "text-red-400"}`}>
                  {si?.icon} {si?.name}: {data.strategy_return_pct >= 0 ? "+" : ""}{data.strategy_return_pct.toFixed(2)}%
                </span>
              </div>
            </div>

            {/* Stats grid */}
            <div className="grid grid-cols-3 gap-3">
              <div className="bg-gray-900/50 border border-gray-700 rounded-xl p-4 text-center">
                <div className="text-xs text-slate-400">🟡 BNB Price</div>
                <div className="text-sm text-slate-300">
                  ${data.start_price.toFixed(2)} → <span className="text-white font-bold">${data.end_price.toFixed(2)}</span>
                </div>
              </div>
              <div className="bg-gray-900/50 border border-gray-700 rounded-xl p-4 text-center">
                <div className="text-xs text-slate-400">🪙 BNB Bought</div>
                <div className="text-xl font-bold text-yellow-400 font-mono">{data.bnb_bought.toFixed(4)}</div>
              </div>
              <div className="bg-gray-900/50 border border-gray-700 rounded-xl p-4 text-center">
                <div className="text-xs text-slate-400">vs Buy & Hold</div>
                <div className={`text-xl font-bold font-mono ${diff >= 0 ? "text-green-400" : "text-red-400"}`}>
                  {diff >= 0 ? "+" : ""}{diff.toFixed(1)}%
                </div>
              </div>
            </div>

            {/* Equity curve + trades */}
            {data.strategy !== "hold" && (
              <div className="bg-gray-900/50 border border-gray-700 rounded-xl p-4">
                <div className="flex justify-between items-center mb-3">
                  <span className="text-sm font-bold text-slate-300">
                    {si?.icon} {si?.name} · {data.strategy_trades} trades
                  </span>
                  <span className="text-xs text-slate-500">
                    ${data.investment} → ${(data.investment * (1 + data.strategy_return_pct / 100)).toFixed(2)}
                  </span>
                </div>
                <div className="flex items-end gap-[1px] h-32 overflow-hidden rounded-lg bg-black/20">
                  {data.equity_curve.filter((_, i) => i % Math.max(1, Math.ceil(data.equity_curve.length / 80)) === 0).map((v, i) => {
                    const h = ((v - eqMin) / eqRange) * 100;
                    return <div key={i} className="flex-1 rounded-t transition-all"
                      style={{ height: `${Math.max(3, h)}%`, background: v >= data.investment ? "#22c55e" : "#ef4444", opacity: 0.7 }} />;
                  })}
                </div>
                <div className="flex justify-between text-[10px] text-slate-500 mt-1.5 px-1">
                  <span>${eqMin.toFixed(0)}</span>
                  <span className="font-mono text-slate-400">Equity range: ${eqMin.toFixed(0)} – ${eqMax.toFixed(2)}</span>
                  <span>${eqMax.toFixed(0)}</span>
                </div>
              </div>
            )}
          </div>
        )}

        {/* Empty state */}
        {!data && !loading && (
          <div className="text-center py-16 text-slate-500">
            <div className="text-6xl mb-4">🟡</div>
            <p className="text-lg">Pick a time period, investment, and strategy.</p>
            <p className="text-sm mt-1">Click &ldquo;Rewind Time&rdquo; to see what could have been.</p>
          </div>
        )}
      </div>

      {showTour && <AutoTour onComplete={() => setShowTour(false)} />}
    </main>
  );
}
